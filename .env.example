# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=replace-with-32-plus-random-chars
TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key
CRON_SECRET=replace-with-cron-secret

# Database - MongoDB Atlas recommended for production.
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/insta_automat?retryWrites=true&w=majority"

# Meta
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=choose-a-random-token

# Optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
